# Supabase (값은 NON-14 콘솔 세팅에서 확보)
# 둘 다 공개(브라우저 노출) 키 — 비밀 키(service_role)는 여기에 두지 말 것
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLISHABLE_KEY

# .NET Api (게이트웨이) — 프로필 조회/프로비저닝 등 데이터 호출 대상
# 로컬 개발: http://localhost:5177 / 프로덕션: https://api.umbyul.com
NEXT_PUBLIC_API_URL=http://localhost:5177

# 사이트 정식 오리진 — canonical/sitemap/robots/OG 절대경로 기준. 미설정 시 https://umbyul.com 폴백.
# 로컬: http://localhost:3000 / 프로덕션: https://umbyul.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 후원 링크(NON-156) — Ko-fi 프로필 URL. 미설정 시 후원 페이지 버튼 숨김.
NEXT_PUBLIC_KOFI_URL=https://ko-fi.com/YOUR_HANDLE

# Cloudflare Turnstile 봇 방어(가입·로그인·비번재설정). 미설정 시 위젯 미표시(개발 무해).
# 공개 site key만 여기에 — secret은 Supabase 대시보드(Auth > Captcha)에 넣고 여기 두지 말 것.
# 활성화하려면 Supabase Auth에서 Captcha도 켜야 서버측 검증됨.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
