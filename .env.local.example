# Supabase (값은 NON-14 콘솔 세팅에서 확보)
# 둘 다 공개(브라우저 노출) 키 — 비밀 키(service_role)는 여기에 두지 말 것
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLISHABLE_KEY

# .NET Api (게이트웨이) — 프로필 조회/프로비저닝 등 데이터 호출 대상
# 로컬 개발: http://localhost:5177 / 프로덕션: https://api.umbyul.com
NEXT_PUBLIC_API_URL=http://localhost:5177

# 후원 링크(NON-156) — Ko-fi 프로필 URL. 미설정 시 후원 페이지 버튼 숨김.
NEXT_PUBLIC_KOFI_URL=https://ko-fi.com/YOUR_HANDLE
